{
  "productName": "GoviewPro",
  "identifier": "com.pake.GoviewPro",
  "version": "0.0.0",
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "png/goview_32.png",
      "iconAsTemplate": false,
      "id": "goviewpro-tray"
    },
    "security": {
      "csp": null
    }
  },
  "build": {
    "frontendDist": "http://goviewlink.com:5858",
    "devUrl": "http://localhost:8080"
  },
  "bundle": {
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "your public key",
      "endpoints": [
        "https://github.com/username/reponame/releases/latest.json"
      ]
    }
  }
}
